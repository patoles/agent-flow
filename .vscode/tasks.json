{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-extension",
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\]",
          "endsPattern": "^Watching for changes\\.\\.\\."
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
